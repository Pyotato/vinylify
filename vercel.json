{
  "rewrites": [
    {
      "source": "/genius/api/:path",
      "destination": "https://api.genius.com/:path"
    },
    {
      "source": "/lyrics",
      "destination": "https://vinylify-express.vercel.app/lyrics"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
